{
  "name": "@agent-xmpp/protocol",
  "version": "0.1.0",
  "description": "Shared XMPP agent gateway protocol types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && node ../../../node_modules/typescript/bin/tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
