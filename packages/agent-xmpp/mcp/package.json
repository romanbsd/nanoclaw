  },
  "dependencies": {
    "@agent-xmpp/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
