{
  "name": "@agent-xmpp/mcp",
  "version": "0.1.0",
  "description": "MCP server exposing XMPP gateway tools to agent containers",
  "type": "module",
  "bin": {
    "agent-xmpp-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "node ../../../node_modules/typescript/bin/tsc",
    "typecheck": "tsc --noEmit",
