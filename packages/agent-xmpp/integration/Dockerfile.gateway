FROM node:22-bookworm-slim

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages/agent-xmpp/protocol/package.json packages/agent-xmpp/protocol/
COPY packages/agent-xmpp/gateway/package.json packages/agent-xmpp/gateway/

RUN pnpm install --frozen-lockfile --filter @agent-xmpp/gateway...

COPY packages/agent-xmpp/protocol packages/agent-xmpp/protocol
COPY packages/agent-xmpp/gateway packages/agent-xmpp/gateway

RUN pnpm --filter @agent-xmpp/protocol build && pnpm --filter @agent-xmpp/gateway build

EXPOSE 9220

CMD ["node", "packages/agent-xmpp/gateway/dist/index.js"]
