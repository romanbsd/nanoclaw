{
  "name": "orchestrator",
  "version": "1.0.0",
  "description": "XMPP agent identity provisioning via OpenFire REST API",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc",
    "typecheck": "tsc --noEmit",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "start": "node ../../node_modules/tsx/dist/cli.mjs src/server.ts"
  },
  "dependencies": {
    "fastify": "5.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
