{
  "name": "@agent-xmpp/orchestrator",
  "version": "1.0.0",
  "description": "XMPP agent identity provisioning via OpenFire REST API",
  "license": "ISC",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit --types node",
    "test": "node ../../node_modules/vitest/vitest.mjs run"
  },
  "dependencies": {
    "@agent-xmpp/protocol": "workspace:*",
    "fastify": "5.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
